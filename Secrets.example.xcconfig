// Copy this file to Secrets.xcconfig and fill in real values.
// Secrets.xcconfig is gitignored — never commit it.

// The lobby endpoint base. Most operators do not change this.
PITWALL_LOBBY_URL = https:/$()/pitwall.m1circuit.com/lobby

// Shared client key. Generate on the server with:
//   openssl rand -base64 48
// Must match the value of PITWALL_CLIENT_KEY in infra/.env on the MC VPS.
PITWALL_CLIENT_KEY = DEV-CLIENT-KEY-1234567890abcdef
